---
environments:
  devlocal:
    values:
      - envs/devlocal.yaml

---
releases:
  - name: local-path-provisioner
    chart: ./charts/local-path-provisioner-0.0.35.tgz
    values:
      - nodePathMap:
        - node: DEFAULT_PATH_FOR_NON_LISTED_NODES
          paths:
          - /opt/local-path-provisioner
          - {{ .Values.nodePathMap }}